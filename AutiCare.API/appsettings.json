{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "AllowedOrigins": [
        "http://localhost:3000",
        "https://auticare-production.up.railway.app"
    ],
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=auticaredb;Username=postgres;Password=123456"
