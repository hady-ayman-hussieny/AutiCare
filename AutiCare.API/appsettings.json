{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://auticare-production.up.railway.app"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=auticare;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Secret": "THIS_IS_MY_SUPER_SECRET_KEY_1234567890_MIN_32_CHARS",
    "Issuer": "AutiCareAPI",
    "Audience": "AutiCareClient",
    "ExpiryMinutes": 60
  },
  "AIService": {
    "BaseUrl": "http://localhost:5001"
  },
  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  }
}